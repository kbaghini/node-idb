{
  "name": "node-idb",
  "version": "0.2.0",
  "description": "An embedded SQLite document store for Node.js with typed values, SQL-style queries, automatic indexes, and a local browser Studio.",
  "type": "module",
  "main": "./src/index.js",
  "module": "./src/index.js",
  "types": "./src/index.d.ts",
  "bin": {
    "node-idb": "bin/node-idb.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./studio": {
      "types": "./src/studio/index.d.ts",
      "import": "./src/studio/index.js",
      "default": "./src/studio/index.js"
    }
  },
  "files": [
    "src",
    "examples",
    "docs",
    "benchmarks",
    "bin",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "node --test && npm run test:types",
    "test:types": "tsc --noEmit --skipLibCheck --module NodeNext --moduleResolution NodeNext --target ES2022 tests/idb-options.types.ts tests/idb-studio.types.ts",
    "pack:check": "npm pack --dry-run",
    "benchmark": "node benchmarks/run.js --preset standard",
    "benchmark:quick": "node benchmarks/run.js --preset quick"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "keywords": [
    "sqlite",
    "sqlite3",
    "database",
    "document-store",
    "document-database",
    "nosql",
    "nodejs",
    "typed-storage",
    "json-database",
    "embedded-database",
    "transactions",
    "upsert",
    "query-builder",
    "database-gui",
    "database-studio",
    "admin-ui",
    "sqlite-gui",
    "idb"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kbaghini/node-idb.git"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "bugs": {
    "url": "https://github.com/kbaghini/node-idb/issues"
  },
  "homepage": "https://github.com/kbaghini/node-idb#readme",
  "license": "MIT",
  "author": "Kamran Baghini",
  "dependencies": {
    "sqlite-parser": "^1.0.1",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
